  save_to_trip: { variant: 'view_my_plan', showCount: true },
};

function BlockRenderer({ type }: { type: string }) {
  const Component = getBlock(type as any);
  if (!Component) return <div style={{ padding: 40, textAlign: 'center', color: '#94a3b8' }}>Block type "{type}" niet gevonden</div>;

  const props = SAMPLE_PROPS[type] || {};

  return (
    <div
      data-block-type={type}
      style={{ width: '100%', minHeight: 200, background: '#fff', borderBottom: '2px solid #e2e8f0' }}
    >
      <Component {...props} />
    </div>
  );
}

function ShowcaseContent() {
  const searchParams = useSearchParams();
  const singleType = searchParams.get('type');

  if (singleType) {
    return <BlockRenderer type={singleType} />;
  }

  // Render all blocks
  return (
    <div>
      {Object.keys(SAMPLE_PROPS).map(type => (
        <div key={type} id={`block-${type}`}>
          <div style={{ padding: '8px 16px', background: '#f1f5f9', fontSize: 12, fontWeight: 600, color: '#64748b', textTransform: 'uppercase', letterSpacing: '0.05em' }}>
            {type}
          </div>
          <BlockRenderer type={type} />
        </div>
      ))}
    </div>
  );
}

export default function BlockShowcasePage() {
  return (
    <Suspense fallback={<div>Loading...</div>}>
      <ShowcaseContent />
    </Suspense>
  );
}
