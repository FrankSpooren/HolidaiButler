'use client';

/**
 * Block Showcase — destination-neutral thumbnail renderer
 * Renders each block type with generic placeholder content.
 * Used by generate-thumbnails.mjs for Puppeteer screenshots.
 *
 * Route: /__block-showcase?type=hero (renders single block)
 * Route: /__block-showcase (renders all blocks sequentially)
 */

import { useSearchParams } from 'next/navigation';
import { Suspense } from 'react';
import { getBlock } from '@/blocks/index';

// Destination-neutral sample props per block type
const SAMPLE_PROPS: Record<string, Record<string, unknown>> = {
