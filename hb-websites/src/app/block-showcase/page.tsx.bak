  faq: { items: [{ question: 'Hoe kom ik er?', answer: 'Er zijn verschillende vervoersmogelijkheden beschikbaar.' }, { question: 'Wat is de beste tijd om te bezoeken?', answer: 'Elk seizoen heeft zijn eigen charme.' }, { question: 'Zijn er activiteiten voor kinderen?', answer: 'Ja, er zijn tal van gezinsvriendelijke activiteiten.' }] },
  testimonials: {},
  partners: { items: [] },
  downloads: { items: [{ title: 'Wandelroute (PDF)', type: 'pdf', size: '3.2 MB' }, { title: 'Fietsroute (GPX)', type: 'gpx', size: '1.1 MB' }] },
