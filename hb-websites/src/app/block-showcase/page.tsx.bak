  event_calendar: { title: 'Evenementen', limit: 6, layout: 'list' },
  event_calendar_filtered: { title: 'Evenementen deze week', limit: 6 },
  map: { height: '400px', overlayLabel: 'Ontdek alle locaties' },
  map_list: { source: 'pois', layout: 'split_60_40', height: 'medium', limit: 10, title: 'Verken de kaart' },
  map_preview: { height: '300px' },
  mobile_map: { height: '250px' },
  category_grid: { layout: 'auto' },
