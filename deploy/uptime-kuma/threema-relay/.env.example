# threema-relay credentials — KOPIEER naar .env op de monitor-host en vul in.
# Zelfde waarden als /etc/threema-alert.env op prod (zelfde Threema Gateway).
#
#   cp .env.example .env && chmod 0600 .env
#
# .env staat in .gitignore en mag NOOIT gecommit worden.

THREEMA_GATEWAY_ID=*XXXXXXX
THREEMA_SECRET=vul-hier-het-gateway-secret-in
OWNER_THREEMA_ID=XXXXXXXX

# Optioneel gedeeld geheim. Zet je dit, dan moet UptimeKuma's webhook de header
# X-Relay-Token meesturen met exact dezelfde waarde (defense-in-depth naast
# het feit dat de relay alleen intern op het Docker-net bereikbaar is).
RELAY_TOKEN=

# Optioneel; default 8099
PORT=8099
